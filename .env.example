# ==============================================================================
# AI PETS - Cyberspace Telemetry Dashboard Environment Configurations Template
# ==============================================================================

# Target IP address of the physical AMOLED ESP32 Desktop Buddy on your local network.
# Enter your Buddy's Tailscale or local Wi-Fi IP to trigger visual mirror syncs.
BUDDY_IP=100.74.116.128

# --- Telegram Configuration ---
# Telegram Bot HTTP API Token (Create one via @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=8605335032:YOUR_TG_BOT_TOKEN_HERE

# Comma-separated list of Telegram User IDs allowed to query your Bot (e.g. 123456789)
ALLOWED_USERS=123456789

# Comma-separated list of Telegram Group Chat IDs allowed (e.g. -1001234567890)
ALLOWED_GROUPS=-1001234567890

# Optional fallback Telegram Chat ID for automated outbound status pings
GROUP_CHAT_ID=0

# --- Discord Configuration ---
# Discord Bot Token (Obtain from the Discord Developer Portal -> Bot -> Token)
DISCORD_BOT_TOKEN=MTQ5NzAwNjIzMDg5ODYwNjI3Mg.GbzY64.YOUR_DISCORD_BOT_TOKEN_HERE

# Discord User ID allowed to interact with the channel bot (e.g. 1469258390193700929)
DISCORD_ALLOWED_USERS=1469258390193700929

# Channel ID where your Discord companion bot polls and listens (e.g. 1497008758675472534)
DISCORD_CHANNEL_ID=1497008758675472534

# --- Agent Platform Integrations ---
# GitHub Personal Access Token (PAT) with 'repo' scope to enable automated telemetry checks
AGENT_GITHUB_PAT=github_pat_YOUR_PAT_TOKEN_HERE

# Brave Search API Key to empower your companion with live cyberspace web searching
BRAVE_SEARCH_API=BSAjmLOZFNz9BYOUR_BRAVE_SEARCH_KEY_HERE

# --- Local Emitter Daemon fallback configs ---
# URL where your local Next.js Web HUD is running (e.g. http://localhost:3000)
AIPETS_DASHBOARD_URL=http://localhost:3000

# Primary Google Gemini API key used by the background bot responders and HUD synthesis
GEMINI_API_KEY=AIzaSyYOUR_GEMINI_KEY_HERE
AIPET_NAME=GhostScout
AIPET_CLASS=Cyber-Egg
